# Copia este archivo como .env y completa con tus valores reales

# MongoDB Atlas (solo si usas conexión directa, sin API)
MONGO_DB_URL=mongodb+srv://usuario:password@cluster.mongodb.net/tracktoger

# API Backend - URL pública cuando desplegues en Render
# Desarrollo local emulador: http://10.0.2.2:3000
# Producción: https://tracktoger-api.onrender.com
API_BASE_URL=https://tracktoger-api.onrender.com

# SendGrid (correos de verificación y recuperación de contraseña)
SENDGRID_API_KEY=tu_api_key_de_sendgrid
SENDGRID_FROM_EMAIL=tu_email_verificado@dominio.com
